# =============================================================================
# stockwise LLM 配置
#
# 支持两类 provider：
#   1. anthropic  ——  官方 Claude API，或兼容 Anthropic 协议的代理转发
#   2. openai     ——  OpenAI 兼容协议端点（DeepSeek / Kimi / 智谱 GLM 等）
#
# 选择方式：
#   - 显式设置 STOCKWISE_PROVIDER=anthropic|openai
#   - 或不设，工具按 KEY 自动识别（仅设了 OPENAI_API_KEY 视为 openai，否则 anthropic）
# =============================================================================

# ---- 方案 A：Anthropic 官方 Claude ----
ANTHROPIC_API_KEY=sk-ant-...
# STOCKWISE_MODEL=claude-sonnet-4-6


# ---- 方案 B：Claude API 代理转发 ----
# 走第三方代理（如 OneAPI / Cloudflare Worker / New API），仍然是 Anthropic 协议
# ANTHROPIC_API_KEY=sk-...
# 或 Claude Code 风格 Bearer Token：
# ANTHROPIC_AUTH_TOKEN=sk-...
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# STOCKWISE_MODEL=claude-sonnet-4-6
# 自签证书代理 + 绕过系统 SOCKS 代理（按需开启）：
# STOCKWISE_INSECURE_SSL=1
# STOCKWISE_TRUST_ENV=0


# ---- 方案 C：DeepSeek ----
# STOCKWISE_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# STOCKWISE_MODEL=deepseek-chat


# ---- 方案 D：Kimi (Moonshot) ----
# STOCKWISE_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.moonshot.cn/v1
# STOCKWISE_MODEL=moonshot-v1-128k


# ---- 方案 E：智谱 GLM ----
# STOCKWISE_PROVIDER=openai
# OPENAI_API_KEY=...
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# STOCKWISE_MODEL=glm-4-plus


# =============================================================================
# 可选：Tushare Pro Token（启用研发占比 / 资本支出精细字段）
# 注册 https://tushare.pro 获取，无 token 时该模块静默跳过
# =============================================================================
# TUSHARE_TOKEN=your-token-here


# ---- 方案 F：通用 OpenAI 兼容端点 ----
# STOCKWISE_PROVIDER=openai
# STOCKWISE_API_KEY=...
# STOCKWISE_BASE_URL=https://your-endpoint/v1
# STOCKWISE_MODEL=your-model-name
